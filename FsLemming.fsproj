<Project Sdk="Microsoft.NET.Sdk">

  <!-- Fable needs a TFM to restore against; the code is compiled to JS, not run
       on .NET. Fable 5 targets net10.0. -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="src/Types.fs" />
    <Compile Include="src/World.fs" />
    <Compile Include="src/Lemming.fs" />
    <Compile Include="src/Inventory.fs" />
    <Compile Include="src/Game.fs" />
    <Compile Include="src/LevelJson.fs" />
    <Compile Include="src/Storage.fs" />
    <Compile Include="src/Levels.fs" />
    <Compile Include="src/Sprites.fs" />
    <Compile Include="src/Render.fs" />
    <Compile Include="src/App.fs" />
    <Compile Include="src/Editor.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Fable.Core" Version="5.1.0" />
    <PackageReference Include="Fable.Browser.Dom" Version="2.20.0" />
  </ItemGroup>

</Project>
